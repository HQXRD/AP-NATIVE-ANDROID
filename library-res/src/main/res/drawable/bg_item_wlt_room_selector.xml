<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <gradient android:angle="270" android:endColor="@color/clr_main_02" android:startColor="@color/clr_main_04" />
        </shape>
    </item>

    <item>
        <shape>
            <corners android:radius="16dp" />
            <gradient android:angle="270" android:endColor="@color/white" android:startColor="@color/clr_white_a30" />
            <stroke android:width="1dp" android:color="@color/clr_gray_6" />
        </shape>
    </item>
</selector>